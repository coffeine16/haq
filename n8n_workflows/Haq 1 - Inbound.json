    {
      "parameters": {
        "jsCode": "const ctx = $('Parse Intent').first().json;\nconst apps = items.map(i => i.json);\nif (!apps.length || !apps[0].id) return [{ json: { chat_id: ctx.chat_id, reply: 'Aapka abhi koi aavedan nahi hai. Apne baare mein bataiye ya rashan card ki photo bhejiye.' } }];\nconst lines = [];\nfor (const a of apps) {\n  lines.push(`\\u{1F4C4} ${a.scheme_hi || a.scheme_en} \\u2014 ${a.state}${a.app_number ? ' (#' + a.app_number + ')' : ''}`);\n  for (const [i, e] of (a.timeline || []).entries()) {\n    const d = new Date(e.at).toLocaleDateString('en-IN', { day: 'numeric', month: 'short' });\n    lines.push(`  ${i + 1}. ${d} \\u2014 ${e.payload?.to || e.kind}`);\n  }\n}\nreturn [{ json: { chat_id: ctx.chat_id, reply: lines.join('\\n') } }];"
      },
      "name": "Render Timeline",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        224,
