    {
      "parameters": {
        "jsCode": "const ctx = $('Build Classifier Request').first().json;\nlet intent = 'SMALLTALK';\ntry {\n  const raw = $json.candidates?.[0]?.content?.parts?.[0]?.text || '';\n  intent = JSON.parse(raw.replace(/```json|```/g, '').trim()).intent || 'SMALLTALK';\n} catch (e) { /* default SMALLTALK */ }\nreturn [{ json: { ...ctx, intent } }];"
