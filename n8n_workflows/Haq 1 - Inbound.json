        "jsCode": "const ctx = $('Build Field Extract').first().json;\nlet fields = {};\ntry {\n  const raw = $json.candidates?.[0]?.content?.parts?.[0]?.text || '';\n  fields = JSON.parse(raw.replace(/```json|```/g, '').trim());\n} catch (e) {}\nconst clean = Object.fromEntries(Object.entries(fields).filter(([, v]) => v !== null && v !== undefined && v !== ''));\nreturn [{ json: { user_id: ctx.user_id, chat_id: ctx.chat_id, fields: clean } }];"
      },
