    {
      "parameters": {
        "jsCode": "const t = $json.text;\nconst prompt = `Extract profile fields from this message. Output ONLY JSON with any of: { name, age, gender (male|female|other), marital_status (married|widowed|single|divorced), annual_income (number, INR), category (GEN|OBC|SC|ST), district, state (2-letter code, e.g. RJ), occupation }. Use null for absent fields, never guess income. Message: ${t}`;\nreturn [{ json: { ...$json, body: { contents: [{ parts: [{ text: prompt }] }], generationConfig: { responseMimeType: 'application/json', maxOutputTokens: 2000, thinkingConfig: { thinkingBudget: 0 } } } } }];"
      },
