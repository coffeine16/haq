      "parameters": {
        "jsCode": "const user = $json;\nconst msg = $('Message Type').first()?.json?.text ? $('Message Type').first().json : $('Merge Transcript').first().json;\nconst prompt = `Classify the user message into exactly one intent.\\nIntents: PROFILE_INFO, STATUS_QUERY, DOC_QUESTION, CONSENT_YES, OTP_REPLY, SMALLTALK.\\nRules: a 4-8 digit number alone => OTP_REPLY. 'haan'/'yes'/'ok'/'ha' => CONSENT_YES. Mentions of self/family/income/age/job/marital status => PROFILE_INFO. Asking about application progress => STATUS_QUERY.\\nReply with JSON only: {\\\"intent\\\": \\\"...\\\"}\\nMessage: ${msg.text}`;\nreturn [{ json: { user_id: user.id, language: user.language, profile: user.profile, chat_id: msg.chat_id, text: msg.text, body: { contents: [{ parts: [{ text: prompt }] }], generationConfig: { responseMimeType: 'application/json', maxOutputTokens: 2000, thinkingConfig: { thinkingBudget: 0 } } } } }];"
      },
      "name": "Build Classifier Request",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -880,
        240
