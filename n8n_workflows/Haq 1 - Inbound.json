    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH app AS (\n  INSERT INTO applications (user_id, scheme_id, state, deadline_at, tier)\n  SELECT $1, (SELECT (payload->>'scheme_id') FROM events WHERE user_id = $1 AND kind = 'matches_offered' ORDER BY id DESC LIMIT 1), 'ready', now(), NULL\n  RETURNING id\n)\nINSERT INTO events (application_id, user_id, kind, payload)\nSELECT id, $1, 'consent', jsonb_build_object('via', 'telegram') FROM app\nRETURNING application_id;",
        "options": {
          "queryReplacement": "={{ $json.user_id }}"
        }
      },
