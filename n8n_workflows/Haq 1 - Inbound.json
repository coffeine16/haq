    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT a.id, a.state, a.app_number, s.config->'name'->>'hi' AS scheme_hi, s.config->'name'->>'en' AS scheme_en,\n  (SELECT json_agg(json_build_object('at', e.created_at, 'kind', e.kind, 'payload', e.payload) ORDER BY e.created_at)\n   FROM events e WHERE e.application_id = a.id) AS timeline\nFROM applications a JOIN schemes s ON s.id = a.scheme_id\nWHERE a.user_id = $1 ORDER BY a.id DESC LIMIT 3;",
        "options": {
          "queryReplacement": "={{ $json.user_id }}"
        }
      },
      "name": "Fetch Applications",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.4,
      "position": [
        0,
        192
      ],
      "id": "e9186c20-e0b1-45b8-82e9-f153009891bb",
